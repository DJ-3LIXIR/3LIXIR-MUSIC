# Copy to .env for local dev. On Render, set these in the dashboard (Environment).
PORT=3001

# Supabase — same project as the frontend
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key            # used to verify user JWTs
SUPABASE_SERVICE_ROLE_KEY=your-service-key # used to read profiles + track usage (keep secret!)

# Comma-separated list of allowed frontend origins (CORS). Leave blank to allow all.
FRONTEND_ORIGIN=https://3-lixir-music.vercel.app

# Optional: route yt-dlp (YouTube) through a RESIDENTIAL proxy to beat YouTube's
# datacenter-IP rate limits (HTTP 429) and bot wall. Leave blank to go direct.
# Format: http://user:pass@host:port  — use a residential proxy, NOT a free/public
# one (account cookies pass through it, and free proxies are datacenter IPs that
# YouTube blocks the same way).
# YT_PROXY=
